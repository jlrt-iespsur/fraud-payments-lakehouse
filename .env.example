# Demo-only defaults. Do not use these credentials outside local environments.

# PostgreSQL
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=lakehouse
POSTGRES_DB=platform
POSTGRES_PORT=5432

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET=lakehouse
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Kafka
KAFKA_TOPIC=payments
KAFKA_EXTERNAL_PORT=29092
KAFKA_UI_PORT=8082

# Spark
SPARK_UI_PORT_START=4040
SPARK_UI_PORT_END=4050

# Query and BI
TRINO_PORT=8080
SUPERSET_PORT=8088
AIRFLOW_PORT=8081

# Superset
SUPERSET_SECRET_KEY=fraud-superset-secret
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=admin

# Airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=admin

# Neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
